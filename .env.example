# Copie para .env e preencha com os valores do projeto Supabase (Dashboard → Settings → API).
# Nunca commite o arquivo .env com chaves reais.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (modo teste) — apenas chave publicável no front-end
VITE_STRIPE_PUBLIC_KEY=pk_test_51TYeY72abnSfEi4yNfaZpucrtkdkbhR7ynMOBiRO0PDUbhi4CcMw1kmWgsr6R2fgrk4lXjr0aUst1q1s5NI6dPQB0057M6e4iF

# false = login/cadastro real via Supabase; rotas do painel exigem sessão.
# true = botão demo em /entrar (sem rede); rotas protegidas ainda exigem login real se Supabase estiver configurado.
VITE_DEMO_MODE=false

# E2E (Playwright) — utilizador de teste no Supabase
VITE_TEST_EMAIL=
VITE_TEST_PASSWORD=

# E2E — segundo utilizador (convites / RLS multi-contexto)
VITE_TEST_USER2_EMAIL=
VITE_TEST_USER2_PASSWORD=
VITE_TEST_USER2_USERNAME=

# E2E timer rápido — carregado com `vite --mode test` (ver .env.test e playwright.config.ts)
# VITE_E2E_TEST_MODE=true
